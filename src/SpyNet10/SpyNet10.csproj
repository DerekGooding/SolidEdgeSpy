    </Compile>
    <Compile Update="Forms\ComPropertyGrid.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\ComTreeView.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Forms\ComTypeListView.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Forms\ComTypeTreeView.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Forms\EventMonitor.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\GlobalParameterBrowser.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\ListViewEx.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Forms\ObjectBrowser.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="Forms\ProcessBrowser.cs">
