    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SolidEdge.Community.Net9" Version="1.0.1" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="AboutForm.cs">
